# ═══════════════════════════════════════════════
# Intilaqa Dashboard - Environment Variables
# Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Intilaqa Engine (Cloudflare Worker)
NEXT_PUBLIC_INTILAQA_ENGINE_URL=http://localhost:8787
WORKER_ADMIN_API_KEY=

# Paddle Billing
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=
NEXT_PUBLIC_PADDLE_BASIC_PRICE_ID=
NEXT_PUBLIC_PADDLE_ULTIMATE_PRICE_ID=

# WhatsApp / Evolution API
EVOLUTION_API_KEY=
EVOLUTION_API_URL=http://localhost:8080

# Evolution Local Database (Drizzle ORM)
EVOLUTION_DATABASE_URL=postgresql://user:password@localhost:5432/evolution

# Notifications
NEXT_PUBLIC_NOVU_APPLICATION_IDENTIFIER=
